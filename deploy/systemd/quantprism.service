[Unit]
Description=QuantPrism FastAPI service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/quant/Quant
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/opt/quant/Quant/.env
ExecStart=/opt/quant/Quant/scripts/run_prod.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
