{
  "version": 2,
  "installCommand": "pip install fastapi httpx",
  "builds": [
    {
      "src": "vercel_app/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel_app/index.py"
    }
  ],
  "env": {
    "VPS_URL": "https://caotaibanzi.xyz"
  }
}
